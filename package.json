{
  "name": "@domosedov/effector-concurrent",
  "version": "0.2.0",
  "description": "Concurrency helpers for Effector effects with Farfetched-style cancellation.",
  "keywords": [
    "abort",
    "concurrency",
    "effector",
    "effects",
    "farfetched"
  ],
  "license": "MIT",
  "author": "Aleksandr Grigorii <domosedov.dev@gmail.com>",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "check": "vp check",
    "fmt": "vp fmt . --write",
    "lint": "vp lint . --type-aware --tsconfig ./tsconfig.json",
    "test": "vp test run",
    "test:watch": "vp test watch",
    "verify": "vp check && vp test run && vp pack && publint && attw --pack",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "prepublishOnly": "vp pack && publint && attw --pack",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "effector": "^23.4.4",
    "publint": "^0.3.18",
    "typescript": "^5.9.3",
    "vite-plus": "latest"
  },
  "peerDependencies": {
    "effector": "^23.4.4"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
